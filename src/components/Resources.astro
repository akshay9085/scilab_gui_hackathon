---
type ResourceItem = {
  name: string;
  link?: string;
};

type ResourceSection = {
  heading: string;
  items: ResourceItem[];
};

const resourceSections: ResourceSection[] = [
  {
    heading: "Scilab",
    items: [
      {
        name: "Download Scilab",
        link: "https://www.scilab.org/download",
      },
      {
        name: "Completed Scilab case studies",
        link: "https://scilab.in/case-study-project/completed-case-studies",
      },
    ],
  },
  {
    heading: "Scilab GUI Spoken Tutorials",
    items: [
      {
        name: "GUI in Scilab tutorial series",
        link: "https://spoken-tutorial.org/tutorial-search/?search_foss=GUI+in+Scilab&search_language=English",
      },
      {
        name: "Scilab tutorial series",
        link: "https://spoken-tutorial.org/tutorial-search/?search_foss=Scilab&search_language=English",
      },
    ],
  },
  {
    heading: "Submission Checklist",
    items: [
      { name: "Source code" },
      { name: "README/documentation" },
      { name: "Short demo video (less than 2 minutes)" },
      { name: "Problem statement" },
      { name: "GUI screenshots" },
      { name: "Sample outputs/results" },
    ],
  },
];
---

<section class="resources-section items-center" id="resources">
  <div class="resources-main">
    <div>
      <h1 class="section-title items-center text-center">Resources</h1>
      <p class="resource-copy m-3 text-justify">
        Candidates are encouraged to refer to the resources and understand Scilab GUI tools before selecting a project idea.
      </p>
    </div>

    <div class="resource-grid">
      {resourceSections.map((section) => (
        <details class="faq">
          <summary class="question">
            <h3>{section.heading}</h3>
          </summary>
          <div class="answer">
            <ul class="ml-5 mt-2 list-disc">
              {section.items.map((item) => (
                <li>
                  {item.link ? (
                    <a href={item.link} class="resource-link hover:underline" target="_blank" rel="noopener noreferrer">
                      {item.name}
                    </a>
                  ) : (
                    item.name
                  )}
                </li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .resources-section {
    display: flex;
    flex-direction: column;
    width: 100% !important;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5.5rem) 1rem;
    background:
      linear-gradient(135deg, rgba(56, 213, 255, 0.08), rgba(202, 255, 0, 0.035)),
      var(--color-brand-bg);
  }

  .resources-main {
    width: min(1120px, 100%);
    overflow-y: hidden;
    border: 1px solid rgba(56, 213, 255, 0.22);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(15, 32, 55, 0.9), rgba(8, 17, 31, 0.96));
    padding: clamp(1rem, 3vw, 2rem);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }

  .resource-copy,
  .answer li {
    color: var(--color-brand-text);
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 1rem;
    background: transparent;
  }

  .question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-brand-yellow);
    background-color: rgba(202, 255, 0, 0.06);
    padding: 1rem 2rem;
    cursor: pointer;
  }

  .question h3 {
    font-size: 1.3rem;
  }

  .answer {
    padding: 0.75rem 2rem 1rem;
  }

  .faq {
    max-width: 100%;
    border: 1px solid rgba(56, 213, 255, 0.22);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(5, 11, 24, 0.48);
  }

  .resource-link {
    color: var(--color-brand-cyan);
  }

  .resource-link:hover {
    color: var(--color-brand-yellow);
  }

  @media screen and (max-width: 983px) {
    .resources-main {
      width: 95%;
    }
  }

  @media screen and (max-width: 768px) {
    .faq {
      max-width: 90%;
    }
  }
</style>
