<!-------------#front section------------- -->
<section class="hero">
  <video
    id="heroVideo"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    class="bg-video"
  >
    <source src="https://static.fossee.in/scilab/hackathon/scilab-gui-hackathon/sciVidHackathon-2606-v01-fin.mp4" type="video/mp4" />
  </video>

  <div class="overlay"></div>

  <div class="content">
    <p class="initiative">
      An initiative of the <strong>FOSSEE Project,</strong><br />
      Indian Institute of Technology Bombay, India
    </p>
    <h1>Scilab GUI Hackathon</h1>
    <p class="dates">
      <span>Registration:</span> 01 June 2026
      <span class="divider">|</span>
      <span>Hackathon:</span> 01 July 2026 - 31 July 2026
    </p>
    <p class="benefits">Cash prizes, eCertificate and internship opportunities</p>
    <a class="register-link" href="#register">Register</a>
  </div>

  <button id="videoBtn" class="video-btn" type="button" aria-label="Pause background video">
    ⏸
  </button>
</section>

<style>

.hero {
  position: relative;
  min-height: 90vh;
  overflow: hidden;
  background: var(--color-brand-bg);
}

.bg-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.overlay {
  position: absolute;
  inset: 0;
  /* background:
    linear-gradient(
      90deg,
      rgba(var(--color-brand-bg-rgb), 0.9),
      rgba(var(--color-brand-bg-rgb), 0.66) 20%,
      rgba(var(--color-brand-bg-rgb), 0.92)
    ),
    rgba(var(--color-brand-bg-rgb), 0.34); */
}

.content {
  position: relative;
  z-index: 2;
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 6rem 1.5rem 4rem;
  color: var(--color-brand-white);
}

.initiative {
  font-size: clamp(1.3rem, 2.5vw, 2.4rem);
  line-height: 1.25;
  margin: 0 0 1.6rem;
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
}

.content h1 {
  margin: 0;
  color: var(--color-brand-yellow);
  font-size: clamp(3rem, 8vw, 7rem);
  line-height: 0.95;
  font-weight: 900;
  letter-spacing: 0;
  text-shadow:
    0 4px 0 rgba(16, 8, 28, 0.95),
    0 0 0.08em rgba(255, 255, 255, 0.7),
    0 0 0.16em rgba(255, 255, 255, 0.55);
}

.dates {
  margin: 1.9rem 0 0;
  font-size: clamp(1.1rem, 2vw, 2rem);
  line-height: 1.35;
  color: var(--color-brand-white);
}

.dates span,
.benefits {
  color: var(--color-brand-yellow);
}

.divider {
  display: inline-block;
  margin: 0 0.4rem;
}

.benefits {
  margin: 2rem 0 0;
  font-size: clamp(1.1rem, 2vw, 2rem);
}

.register-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: min(18rem, 80vw);
  margin-top: 2.2rem;
  padding: 0.45rem 2.25rem;
  border: 3px solid var(--color-brand-yellow);
  border-radius: 999px;
  color: var(--color-brand-yellow);
  font-size: clamp(1.4rem, 2.6vw, 2.5rem);
  line-height: 1.2;
  text-decoration: none;
  background: rgba(var(--color-brand-bg-rgb), 0.28);
  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.register-link:hover {
  color: var(--color-brand-ink);
  background: var(--color-brand-yellow);
  transform: translateY(-2px);
}

.video-btn {
  position: absolute;
  bottom: 30px;
  right: 30px;
  z-index: 10;

  width: 55px;
  height: 55px;

  border: none;
  border-radius: 50%;

  background: rgba(0, 0, 0, 0.5);
  color: white;

  font-size: 22px;
  cursor: pointer;

  backdrop-filter: blur(5px);

  transition: all 0.3s ease;
}

.video-btn:hover {
  transform: scale(1.1);
  background: rgba(255, 255, 255, 0.2);
}

@media screen and (max-width: 768px) {
  .hero,
  .content {
    min-height: 86vh;
  }

  .content {
    padding-inline: 1rem;
  }

  .dates {
    max-width: 22rem;
  }

  .divider {
    display: none;
  }

  .dates span:not(.divider) {
    display: block;
    margin-top: 0.65rem;
  }
}

</style>
<script is:inline>
  const video = document.getElementById("heroVideo");
  const btn = document.getElementById("videoBtn");

  btn?.addEventListener("click", () => {
    if (!(video instanceof HTMLVideoElement)) return;

    if (video.paused) {
      video.play();
      btn.textContent = "⏸";
      btn.setAttribute("aria-label", "Pause background video");
    } else {
      video.pause();
      btn.textContent = "▶";
      btn.setAttribute("aria-label", "Play background video");
    }
  });
</script>
