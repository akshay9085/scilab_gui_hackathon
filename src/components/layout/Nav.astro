    <div class="nav-actions">
      <button data-section-theme-toggle type="button" class="theme-toggle" aria-pressed="false" aria-label="Switch section content to light mode" data-theme-state="dark">
        <svg class="theme-toggle-icon theme-toggle-icon-light" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 9c1.654 0 3 1.346 3 3s-1.346 3-3 3-3-1.346-3-3 1.346-3 3-3zm0-2c-2.762 0-5 2.238-5 5s2.238 5 5 5 5-2.238 5-5-2.238-5-5-5zm-4.184-.599l-3.593-3.594-1.415 1.414 3.595 3.595c.401-.537.876-1.013 1.413-1.415zm4.184-1.401c.34 0 .672.033 1 .08v-5.08h-2v5.08c.328-.047.66-.08 1-.08zm5.598 2.815l3.595-3.595-1.414-1.414-3.595 3.595c.537.402 1.012.878 1.414 1.414zm-12.598 4.185c0-.34.033-.672.08-1h-5.08v2h5.08c-.047-.328-.08-.66-.08-1zm11.185 5.598l3.594 3.593 1.415-1.414-3.594-3.593c-.403.536-.879 1.012-1.415 1.414zm-9.784-1.414l-3.593 3.593 1.414 1.414 3.593-3.593c-.536-.402-1.011-.877-1.414-1.414zm12.519-5.184c.047.328.08.66.08 1s-.033.672-.08 1h5.08v-2h-5.08zm-6.92 8c-.34 0-.672-.033-1-.08v5.08h2v-5.08c-.328.047-.66.08-1 .08z" fill="currentColor"></path>
        </svg>
        <svg class="theme-toggle-icon theme-toggle-icon-dark" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.719 2.082c-2.572 2.028-4.719 5.212-4.719 9.918 0 4.569 1.938 7.798 4.548 9.895-4.829-.705-8.548-4.874-8.548-9.895 0-5.08 3.808-9.288 8.719-9.918zm1.281-2.082c-6.617 0-12 5.383-12 12s5.383 12 12 12c1.894 0 3.87-.333 5.37-1.179-3.453-.613-9.37-3.367-9.37-10.821 0-7.555 6.422-10.317 9.37-10.821-1.74-.682-3.476-1.179-5.37-1.179zm0 10.999c1.437.438 2.562 1.564 2.999 3.001.44-1.437 1.565-2.562 3.001-3-1.436-.439-2.561-1.563-3.001-3-.437 1.436-1.562 2.561-2.999 2.999zm8.001.001c.958.293 1.707 1.042 2 2.001.291-.959 1.042-1.709 1.999-2.001-.957-.292-1.707-1.042-2-2-.293.958-1.042 1.708-1.999 2zm-1-9c-.437 1.437-1.563 2.562-2.998 3.001 1.438.44 2.561 1.564 3.001 3.002.437-1.438 1.563-2.563 2.996-3.002-1.433-.437-2.559-1.564-2.999-3.001z" fill="currentColor"></path>
        </svg>
        <span class="sr-only">Toggle section theme</span>
      </button>
      <button data-collapse-toggle="navbar-solid-bg" type="button" class="menu-toggle inline-flex items-center p-2 w-10 h-10 justify-center text-sm rounded-full md:hidden" aria-controls="navbar-solid-bg" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
          </svg>
      </button>
    </div>
  </div>
</nav>


         
<style>
  .nav-frame {
    z-index: 999;
    padding: 1rem 1rem 0;
    background: transparent;
    color: var(--color-brand-yellow);
    pointer-events: none;
  }

  .nav-shell {
    width: min(980px, calc(100% - 2rem));
    min-height: 4.35rem;
    padding: 0.72rem 0.9rem;
    border: 1px solid rgba(56, 213, 255, 0.2);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
      rgba(var(--color-brand-bg-rgb), 0.78);
    box-shadow:
      0 18px 46px rgba(0, 0, 0, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(16px);
    pointer-events: auto;
  }

  .brand-link {
    order: 1;
    color: var(--color-brand-yellow);
    text-decoration: none;
    white-space: nowrap;
  }

  .brand-mark {
    display: inline-flex;
    width: 2.2rem;
    height: 2.2rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(202, 255, 0, 0.35);
    border-radius: 12px;
    background: rgba(202, 255, 0, 0.12);
    box-shadow: 0 0 22px rgba(202, 255, 0, 0.2);
  }

  .brand-title {
    color: var(--color-brand-white);
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1;
  }

  nav svg,
  .nav-link {
    color: var(--color-brand-yellow);
  }

  .nav-list {
    gap: 1rem;
  }

  #navbar-solid-bg {
    order: 2;
  }

  .nav-actions {
    order: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 2.35rem;
    height: 2.35rem;
    padding: 0;
    border: 1px solid rgba(202, 255, 0, 0.24);
    border-radius: 50%;
    background: rgba(202, 255, 0, 0.12);
    color: var(--color-brand-yellow);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .theme-toggle:hover {
    color: var(--color-brand-white);
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
  }

  .theme-toggle-icon {
    width: 1.25rem;
    height: 1.25rem;
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%) scale(0.7) rotate(-20deg);
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .theme-toggle[data-theme-state="dark"] .theme-toggle-icon-light,
  .theme-toggle[data-theme-state="light"] .theme-toggle-icon-dark {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) rotate(0deg);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.42rem 0.45rem;
    border-radius: 999px;
    font-size: 0.95rem;
    line-height: 1.25rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-brand-white);
    background: rgba(255, 255, 255, 0.08);
  }

  a.nav-link.active {
    color: var(--color-brand-yellow);
    background: rgba(202, 255, 0, 0.12);
    box-shadow: inset 0 0 0 1px rgba(202, 255, 0, 0.2);
  }

  .menu-toggle {
    color: var(--color-brand-yellow);
    background: rgba(255, 255, 255, 0.08);
  }

  .menu-toggle:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  @media only screen and (max-width: 767px) {
    .nav-shell {
      width: min(92vw, 28rem);
      border-radius: 26px;
    }

    #navbar-solid-bg {
      order: 3;
      margin-top: 0.85rem;
      padding-top: 0.85rem;
      border-top: 1px solid rgba(56, 213, 255, 0.16);
    }

    .nav-actions {
      order: 2;
      margin-left: auto;
    }

    .nav-list {
      display: grid;
      gap: 0.35rem;
    }

    .nav-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>
 
