---
import navLinks from "./nav-links.json";
---

<script>
// hashchange added because js not loading on same page 
window.addEventListener('hashchange', () => {
  addActiveClass(); 
});
document.addEventListener('DOMContentLoaded', () => {
  addActiveClass(); 
  initSectionTheme();
});



function addActiveClass() {
  if(window.location.hash){
    var currentUrl = window.location.pathname + window.location.hash.replace(/\/+$/, ''); 
    // console.log(currentUrl);
  }
  else{
    var currentUrl = window.location.pathname.replace(/\/+$/, '') + window.location.hash; 
  }
    var menuItems = document.querySelectorAll('.nav-link');

    menuItems.forEach(item => {
        var menuItemUrl = item.getAttribute('href'); 
        // console.log(menuItemUrl); 

     
        if (currentUrl === menuItemUrl || window.location.hash === menuItemUrl) {
            item.classList.add("active");
        } else {
            item.classList.remove("active");
        }
    });
}

function initSectionTheme() {
  var button = document.querySelector('[data-section-theme-toggle]');
  if (!button) return;

  var storedTheme = getStoredSectionTheme();
  var initialTheme: "light" | "dark" = storedTheme === 'light' ? 'light' : 'dark';

  setSectionTheme(initialTheme);

  button.addEventListener('click', () => {
    var nextTheme: "light" | "dark" = document.documentElement.dataset.sectionTheme === 'light' ? 'dark' : 'light';
    setSectionTheme(nextTheme);
  });
}

function setSectionTheme(theme: "light" | "dark") {
  var button = document.querySelector('[data-section-theme-toggle]');

  document.documentElement.dataset.sectionTheme = theme;
  try {
    localStorage.setItem('section-theme', theme);
  } catch {
    // Ignore storage failures; the toggle still works for the current page.
  }

  if (!(button instanceof HTMLElement)) return;

  var isLight = theme === 'light';
  button.setAttribute('aria-pressed', String(isLight));
  button.setAttribute('aria-label', isLight ? 'Switch section content to dark mode' : 'Switch section content to light mode');
  button.dataset.themeState = theme;
}

function getStoredSectionTheme() {
  try {
    return localStorage.getItem('section-theme');
  } catch {
    return null;
  }
}

 
    </script>



<nav class="nav-frame fixed top-0 left-0 z-50 w-full">
  <div class="nav-shell flex flex-wrap items-center justify-between mx-auto">
    <a href="/" class="brand-link flex items-center space-x-3 rtl:space-x-reverse">
        <!-- <img src="https://flowbite.com/docs/images/logo.svg" class="h-8" alt="gui" /> -->
        <span class="brand-mark">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </span>
        <span class="brand-title">Scilab GUI</span>
        
        <!-- <span class="typewriter self-center text-3xl font-extrabold whitespace-nowrap dark:text-white bg-gradient-to-r from-blue-600 via-green-500 to-indigo-400 inline-block text-transparent bg-clip-text">GUI Competition</span> -->
    </a>
    <div class="hidden w-full md:block md:w-auto" id="navbar-solid-bg">
      <ul class="nav-list font-medium mt-4 rounded-lg md:flex md:items-center md:mt-0">
        {
          navLinks.map((link) => {
            const { label, href } = link;

            return (
